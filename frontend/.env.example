# URL API Backend (leave empty for local dev proxy)
VITE_API_URL=

# Midtrans API Sandbox Client Key (Safe for frontend exposure)
VITE_MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxxxxxx

# Backend Secrets - DO NOT prefix with VITE_ or expose to frontend files.
# Included here for configuration reference:
# MIDTRANS_SERVER_KEY=your_midtrans_server_key_here
# GEMINI_API_KEY=your_gemini_api_key_here
